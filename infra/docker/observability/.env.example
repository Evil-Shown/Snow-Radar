# Snow Radar Observability Stack - Environment Variables
# Copy to .env and fill in values

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme123

# Alertmanager (optional - for email/Discord alerts)
SMTP_PASSWORD=your-smtp-app-password
DISCORD_WEBHOOK_ID=your-webhook-id
DISCORD_WEBHOOK_TOKEN=your-webhook-token

# Prometheus remote write (optional)
# REMOTE_WRITE_URL=https://prometheus.example.com/api/v1/write
# REMOTE_WRITE_USERNAME=user
# REMOTE_WRITE_PASSWORD=pass